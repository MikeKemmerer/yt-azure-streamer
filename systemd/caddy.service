[Unit]
Description=Caddy Web Server
After=network-online.target

[Service]
Type=notify
ExecStart=/usr/bin/caddy run --environ --config /opt/yt/caddy/Caddyfile
ExecReload=/usr/bin/caddy reload --config /opt/yt/caddy/Caddyfile
Restart=always
RestartSec=5
LimitNOFILE=1048576

[Install]
WantedBy=multi-user.target
