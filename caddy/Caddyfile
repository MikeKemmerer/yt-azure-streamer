CADDY_SITE_ADDRESS {

  # Basic auth — credentials generated at install time from Key Vault secrets
  import /etc/caddy/auth.conf

  # Serve frontend static files
  root * /opt/yt/web/frontend
  file_server

  # Reverse proxy API calls to backend
  handle_path /api/* {
    reverse_proxy localhost:8080
  }

  # Health check (unauthenticated)
  respond /health "OK" 200
}
